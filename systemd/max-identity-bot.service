[Unit]
Description=MAX Identity Bot safe test service
Wants=network-online.target
After=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/zabbix-max-alert-bot
EnvironmentFile=-/opt/zabbix-max-alert-bot/.env
ExecStart=/usr/bin/node /opt/zabbix-max-alert-bot/src/bot-platform/app.js
Restart=always
RestartSec=5
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
