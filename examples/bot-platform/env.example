# MAX bot-platform environment
# Safe test bot service default: long_polling
# Live runtime validation in Task 18.3 uses the same variables.
# Live service uses `node src/bot-platform/app.js --live` with the same local secrets.
# `webhook` is currently a not-implemented live mode and must fail fast.
MAX_API_URL=<synthetic-max-api-url>
MAX_BOT_TOKEN=<synthetic-bot-token>
MAX_HTTP_PROXY=
MAX_LOG_LEVEL=info
MAX_TRANSPORT_MODE=long_polling
MAX_POLL_LIMIT=100
MAX_POLL_TIMEOUT_SECONDS=30
MAX_POLL_TYPES=message_created,bot_started,bot_added

# Queue delivery (ADR-0025, ADR-0028)
# Set QUEUE_ENABLED=true to enable at-least-once delivery via SQLite queue
QUEUE_ENABLED=false
QUEUE_MAX_ATTEMPTS=5
QUEUE_INTERVAL_MS=5000
QUEUE_BATCH_SIZE=10
QUEUE_BACKOFF_BASE=2
QUEUE_BACKOFF_MAX=300

# HTTP-ingress (ADR-0023, ADR-0024)
# Set INGRESS_ENABLED=true to enable POST /ingest endpoint
INGRESS_ENABLED=false
INGRESS_PORT=8443

# IdP (ADR-0027)
# Required when INGRESS_ENABLED=true
# MVP: NanoIDP (local Docker, see docs/nanoidp-setup.md)
# Production: Keycloak or Authentik (see docs/nanoidp-setup.md)
IDP_ISSUER=
IDP_AUDIENCE=bot-platform

# JWT claim configuration for source identification
# NanoIDP: use entitlements array, check for zabbix value
# Okta: use bot_source claim
JWT_CLAIM_NAME=entitlements
JWT_CLAIM_VALUE=zabbix

# Audit trail and lifecycle trace (ADR-0029)
LOG_AUDIT=false
LOG_TRACE=true

# Outbound rate limiting
# Set RATE_LIMIT_ENABLED=false to disable rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL=25
RATE_LIMIT_RECIPIENT=5

# Queue monitor dashboard (ADR-0034, ADR-0035)
# Set MONITOR_ENABLED=true to start dashboard on MONITOR_PORT (default 9000)
# METRICS_API_KEY is required for external monitoring systems (Zabbix, Prometheus, curl).
# UI dashboard uses session auth after OAuth2 login — no manual key entry needed.
MONITOR_ENABLED=false
# MONITOR_PORT=9000
# METRICS_API_KEY=<generate-random-32-char-token>

# OAuth2 UI login (ADR-0034)
# Optional: enables login page with IdP authentication
# When omitted, dashboard serves static UI without login
# IDP_CLIENT_ID=
# IDP_CLIENT_SECRET=
# IDP_REDIRECT_URI=<IDP_REDIRECT_URI>
# SESSION_SECRET=<generate-random-32-char-secret>

# Auth rate limiting (Sprint 23 / M2) — only active when OAuth2 login is enabled.
# Protects /api/auth/login + /api/auth/callback from flood and parallel-blast
# (callback makes outbound calls to the IdP).
# AUTH_RATE_LIMIT=true
# AUTH_RATE_LIMIT_MAX=20            # max auth requests per window
# AUTH_RATE_LIMIT_WINDOW_MS=60000   # sliding window size (ms)
# AUTH_RATE_CONCURRENCY=5           # max simultaneous in-flight callbacks

# OIDC discovery (Sprint 23 / L3) — SSRF hardening.
# IDP endpoints are validated against private/reserved IP ranges before fetch
# (loopback, RFC1918, link-local incl. 169.254.169.254, unique-local).
# IDP_REQUIRE_DISCOVERY=false       # true = fail-fast if /.well-known is unreachable
#                                   #       instead of falling back to /authorize /token /userinfo
